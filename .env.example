# API Backend URL (your Render backend URL in production)
VITE_API_URL=http://localhost:5000

# Supabase Configuration (Get these from https://supabase.com)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Vercel Blob Storage (Automatic if using Vercel)
BLOB_READ_WRITE_TOKEN=your_vercel_token
